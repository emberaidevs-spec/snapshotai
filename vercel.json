{
  "buildCommand": "",
  "outputDirectory": "landing",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.6.0",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
