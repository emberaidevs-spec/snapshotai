{
  "buildCommand": "",
  "outputDirectory": "landing",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.6.0",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/help", "destination": "/docs.html" },
    { "source": "/downloads/SnapShotAI.exe", "destination": "http://5.78.191.207:8766/SnapShotAI.exe" },
    { "source": "/downloads/SnapShotAI.dmg", "destination": "http://5.78.191.207:8766/SnapShotAI.dmg" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
