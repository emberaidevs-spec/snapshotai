{
  "buildCommand": "",
  "outputDirectory": "landing",

  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/help", "destination": "/docs.html" },
    { "source": "/downloads/SnapShotAI.exe", "destination": "/api/download?file=SnapShotAI.exe" },
    { "source": "/downloads/SnapShotAI.dmg", "destination": "/api/download?file=SnapShotAI.dmg" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
