{
  "buildCommand": "",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.6.0",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/dashboard", "destination": "/landing/dashboard.html" },
    { "source": "/pricing", "destination": "/landing/pricing.html" },
    { "source": "/docs", "destination": "/landing/docs.html" },
    { "source": "/help", "destination": "/landing/docs.html" },
    { "source": "/(.*)", "destination": "/landing/index.html" }
  ]
}
